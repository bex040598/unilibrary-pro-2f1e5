APP_NAME=ATMU Smart UniLibrary API
API_PREFIX=
JWT_SECRET_KEY=change-me
JWT_REFRESH_SECRET_KEY=change-me-refresh
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=14
